{
  "name": "@mcp-layer/session",
  "version": "1.0.0",
  "description": "Shared MCP session wrapper used by connect and attach.",
  "repository": {
    "type": "git",
    "url": "https://github.com/3rd-Eden/mcp-layer"
  },
  "type": "module",
  "keywords": [
    "mcp",
    "session",
    "client",
    "transport"
  ],
  "scripts": {
    "build:types": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm run build:types"
  },
  "main": "src/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "types",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
